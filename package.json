{
  "name": "@doscientos/verifactu",
  "version": "0.1.9",
  "description": "Framework-agnostic Verifactu (AEAT) invoice submission, SIF hash chain and QR generation for Node.js.",
  "keywords": [
    "verifactu",
    "aeat",
    "veri-factu",
    "sif",
    "invoice",
    "spain",
    "tax"
  ],
  "license": "MIT",
  "author": "Doscientos <dev@doscientos.es>",
  "repository": {
    "type": "git",
    "url": "https://github.com/doscientos-es/verifactu.git"
  },
  "homepage": "https://github.com/doscientos-es/verifactu#readme",
  "bugs": {
    "url": "https://github.com/doscientos-es/verifactu/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "release:patch": "pnpm version patch",
    "release:minor": "pnpm version minor",
    "release:major": "pnpm version major",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "date-fns-tz": "^3.2.0",
    "fast-xml-parser": "^4.5.1",
    "node-forge": "^1.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-forge": "^1.3.11",
    "@types/qrcode": "^1.5.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.2"
}
